{
    "swagger": "2.0",
    "info": {
        "description": "Backend para la optimización de producción de una panadería usando LINGO.",
        "title": "LINGO Bakery API",
        "contact": {
            "name": "Soporte Técnico"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api",
    "paths": {
        "/ingredients": {
            "get": {
                "description": "Obtiene la lista completa de ingredientes registrados en el sistema",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Ingredients"
                ],
                "summary": "Listar ingredientes",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Ingredient"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Registra un nuevo insumo básico en el sistema",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Ingredients"
                ],
                "summary": "Crear ingrediente",
                "parameters": [
                    {
                        "description": "Datos del ingrediente",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Ingredient"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/models.Ingredient"
                        }
                    }
                }
            }
        },
        "/ingredients/{id}": {
            "get": {
                "description": "Obtiene los detalles de un ingrediente específico",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Ingredients"
                ],
                "summary": "Obtener ingrediente",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID del ingrediente",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Ingredient"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/optimize": {
            "post": {
                "description": "Encola un nuevo trabajo para que LINGO calcule la producción óptima",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Optimization"
                ],
                "summary": "Iniciar optimización",
                "parameters": [
                    {
                        "description": "IDs de Stock y Recursos",
                        "name": "output",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Optimization"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "job_id, status",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/optimize/{job_id}": {
            "get": {
                "description": "Obtiene el estado (pending, processing, done, error) de un trabajo por su UUID y su ID de base de datos",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Optimization"
                ],
                "summary": "Consultar estado de Job",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID del trabajo",
                        "name": "job_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "job_id, status, id",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/products": {
            "get": {
                "description": "Obtiene la lista completa de productos con sus precios y costos",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Products"
                ],
                "summary": "Listar productos",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Product"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Registra un nuevo producto en el catálogo",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Products"
                ],
                "summary": "Crear producto",
                "parameters": [
                    {
                        "description": "Datos del producto",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Product"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/models.Product"
                        }
                    }
                }
            }
        },
        "/products/{id}": {
            "get": {
                "description": "Obtiene detalles de un producto, incluyendo ingredientes y máquinas asignadas",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Products"
                ],
                "summary": "Obtener producto",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID del producto",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Product"
                        }
                    }
                }
            }
        },
        "/results/{id}": {
            "get": {
                "description": "Obtiene las cantidades óptimas a producir y ganancias esperadas",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Optimization"
                ],
                "summary": "Obtener resultados de optimización",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID de la optimización (Postgres)",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Optimization"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "models.Ingredient": {
